<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.project.controller.PatientDashboardController"
            styleClass="root" stylesheets="@../css/style.css">

    <!-- Top Navigation Bar (Removed per user request) -->
    <!-- Left Sidebar Navigation -->
    <left>
        <VBox fx:id="sidebar" spacing="5" styleClass="sidebar">
            <padding>
                <Insets bottom="20" left="15" right="15" top="20" />
            </padding>

            <!-- App Logo/Brand -->
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="sidebar-brand">
                <Label styleClass="brand-icon" text="✚" />
                <Label styleClass="brand-text" text="BUET MedTech" />
                <VBox.margin>
                    <Insets bottom="20" />
                </VBox.margin>
            </HBox>

            <!-- Navigation Menu with ScrollPane -->
            <ScrollPane fitToWidth="true" styleClass="sidebar-scroll" VBox.vgrow="ALWAYS">
                <VBox spacing="5" styleClass="sidebar-menu">
                    <Label styleClass="sidebar-group-label" text="Menu" />
                    <Button fx:id="btnDashboard" alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#showDashboard" styleClass="nav-btn, active" text="📊 Dashboard" />
                    <Button fx:id="btnSearchDoctors" alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#showSearchDoctors" styleClass="nav-btn" text="🔍 Search Doctors" />
                    <Button fx:id="btnBookAppointment" alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#showBookAppointment" styleClass="nav-btn" text="📅 Book Appointment" />
                    <Button fx:id="btnViewAppointments" alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#showViewAppointments" styleClass="nav-btn" text="📋 My Appointments" />
                    <Button fx:id="btnViewReports" alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#showViewReports" styleClass="nav-btn" text="📄 Medical Reports" />
                    <Button fx:id="btnNotifications" alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#showNotifications" styleClass="nav-btn" text="🔔 Notifications" />
                    <Button fx:id="btnDoctorPosts" alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#showDoctorPosts" styleClass="nav-btn" text="💡 Health Tips" />
                    <Button fx:id="btnQA" alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#showQA" styleClass="nav-btn" text="❓ Q&amp;A Forum" />
                    <Button fx:id="btnBloodDonation" alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#showBloodDonation" styleClass="nav-btn" text="🩸 Blood Donation" />
                    <Button fx:id="btnSmartAssistant" alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#showSmartAssistant" styleClass="nav-btn" text="🤖 AI Assistant" />
                    
                    <Region prefHeight="20" />
                </VBox>
            </ScrollPane>

            <!-- Profile & Settings Section at Bottom -->
            <VBox spacing="10" styleClass="sidebar-footer">
                <Separator styleClass="sidebar-separator" />
                
                <Label fx:id="lblWelcome" styleClass="sidebar-user-name" text="Welcome, Patient!" />
                
                <HBox alignment="CENTER" spacing="10" styleClass="mode-toggle-container">
                    <Button fx:id="btnLightMode" onAction="#setLightMode" styleClass="mode-btn, active" text="☀️ Light" />
                    <Button fx:id="btnDarkMode" onAction="#setDarkMode" styleClass="mode-btn" text="🌙 Dark" />
                </HBox>

                <Button fx:id="btnProfile" alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#showProfile" styleClass="nav-btn" text="👤 Profile Setup" />
                <Button fx:id="btnProfileSettings" alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#showProfile" styleClass="nav-btn" text="⚙️ Profile Settings" visible="false" managed="false" />
                
                <Button fx:id="btnLogout" alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#handleLogout" styleClass="nav-btn, logout-btn" text="🚪 Logout" />
            </VBox>
        </VBox>
    </left>

    <!-- Main Content Area -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <!-- Dashboard Section -->
            <VBox fx:id="dashboardSection" spacing="20" visible="true">
                <Label text="Dashboard" styleClass="section-title">
                    <font>
                        <Font name="System Bold" size="24"/>
                    </font>
                </Label>

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="content-scroll-pane">
                    <VBox spacing="22">
                        <GridPane hgap="20" vgap="20">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                    </columnConstraints>

                    <VBox styleClass="stat-card" GridPane.columnIndex="0">
                        <padding>
                            <Insets top="20" right="20" bottom="20" left="20"/>
                        </padding>
                        <Label text="Upcoming Appointments" styleClass="stat-label"/>
                        <Label fx:id="lblUpcomingAppointments" text="0" styleClass="stat-value">
                            <font>
                                <Font name="System Bold" size="32"/>
                            </font>
                        </Label>
                    </VBox>

                    <VBox styleClass="stat-card" GridPane.columnIndex="1">
                        <padding>
                            <Insets top="20" right="20" bottom="20" left="20"/>
                        </padding>
                        <Label text="Total Reports" styleClass="stat-label"/>
                        <Label fx:id="lblTotalReports" text="0" styleClass="stat-value">
                            <font>
                                <Font name="System Bold" size="32"/>
                            </font>
                        </Label>
                    </VBox>

                    <VBox styleClass="stat-card" GridPane.columnIndex="2">
                        <padding>
                            <Insets top="20" right="20" bottom="20" left="20"/>
                        </padding>
                        <Label text="Unread Notifications" styleClass="stat-label"/>
                        <Label fx:id="lblUnreadNotifs" text="0" styleClass="stat-value">
                            <font>
                                <Font name="System Bold" size="32"/>
                            </font>
                        </Label>
                    </VBox>

                    <VBox styleClass="stat-card" GridPane.columnIndex="3">
                        <padding>
                            <Insets top="20" right="20" bottom="20" left="20"/>
                        </padding>
                        <Label text="Blood Donation Status" styleClass="stat-label"/>
                        <Label fx:id="lblBloodDonationStatus" text="Not Registered" styleClass="stat-value-small">
                            <font>
                                <Font name="System Bold" size="16"/>
                            </font>
                        </Label>
                    </VBox>
                        </GridPane>

                        <HBox spacing="18">
                            <VBox styleClass="form-container quick-grid-card" HBox.hgrow="ALWAYS">
                        <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                        <Label text="Stay Updated" styleClass="subsection-title"/>
                        <Label text="See admin alerts, doctor updates and appointment reminders in one place." styleClass="info-text" wrapText="true"/>
                        <Button text="Open Notifications" styleClass="primary-btn" onAction="#showNotifications" prefWidth="200"/>
                            </VBox>

                            <VBox styleClass="form-container quick-grid-card" HBox.hgrow="ALWAYS">
                        <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                        <Label text="Health Feed" styleClass="subsection-title"/>
                        <Label text="Doctor health tips, Q&amp;A replies and report summaries quickly access korun." styleClass="info-text" wrapText="true"/>
                        <HBox spacing="10">
                            <Button text="Health Tips" styleClass="secondary-btn" onAction="#showDoctorPosts" prefWidth="150"/>
                            <Button text="My Reports" styleClass="primary-btn" onAction="#showViewReports" prefWidth="150"/>
                        </HBox>
                            </VBox>

                            <VBox styleClass="form-container quick-grid-card" HBox.hgrow="ALWAYS">
                        <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                        <Label text="Take Action" styleClass="subsection-title"/>
                        <Label text="Appointment book, donor profile update, ar symptom assistant use korun." styleClass="info-text" wrapText="true"/>
                        <HBox spacing="10">
                            <Button text="Book Now" styleClass="primary-btn" onAction="#showBookAppointment" prefWidth="145"/>
                            <Button text="Blood Donor" styleClass="secondary-btn" onAction="#showBloodDonation" prefWidth="145"/>
                        </HBox>
                            </VBox>
                        </HBox>

                        <GridPane hgap="18" vgap="18">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50"/>
                                <ColumnConstraints percentWidth="50"/>
                            </columnConstraints>

                            <VBox styleClass="dashboard-highlight" spacing="12" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                                <Label text="Latest Notifications" styleClass="subsection-title"/>
                                <ListView fx:id="lstDashboardNotifications" prefHeight="260" styleClass="question-list"/>
                            </VBox>

                            <VBox styleClass="dashboard-highlight" spacing="12" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                                <Label text="Recent Health Posts" styleClass="subsection-title"/>
                                <ListView fx:id="lstDashboardPosts" prefHeight="260" styleClass="question-list"/>
                            </VBox>

                            <VBox styleClass="dashboard-highlight" spacing="12" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                                <Label text="My Q&amp;A Activity" styleClass="subsection-title"/>
                                <ListView fx:id="lstDashboardQuestions" prefHeight="260" styleClass="question-list"/>
                            </VBox>

                            <VBox styleClass="dashboard-highlight" spacing="12" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                                <Label text="Available Donors Nearby" styleClass="subsection-title"/>
                                <FlowPane fx:id="dashboardDonorGridPane" hgap="12" vgap="12" prefWrapLength="520"/>
                            </VBox>
                        </GridPane>
                    </VBox>
                </ScrollPane>
            </VBox>

            <!-- Search Doctors Section -->
            <VBox fx:id="searchDoctorsSection" spacing="20" visible="false">
                <Label text="Search Doctors" styleClass="section-title">
                    <font>
                        <Font name="System Bold" size="24"/>
                    </font>
                </Label>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="txtSearchName" promptText="Search by name..." prefWidth="200"/>
                    <TextField fx:id="txtSearchSpecialization" promptText="Specialization..." prefWidth="200"/>
                    <TextField fx:id="txtSearchFee" promptText="Max fee..." prefWidth="150"/>
                    <Button text="Search" styleClass="primary-btn" onAction="#searchDoctors"/>
                    <Button text="Show All" styleClass="secondary-btn" onAction="#showSearchDoctors"/>
                </HBox>

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="content-scroll-pane">
                    <FlowPane fx:id="doctorGridPane" hgap="20" vgap="20" styleClass="doctor-grid-container" orientation="HORIZONTAL">
                        <padding>
                            <Insets top="10" right="10" bottom="20" left="10"/>
                        </padding>
                    </FlowPane>
                </ScrollPane>
            </VBox>

            <!-- Book Appointment Section -->
            <VBox fx:id="bookAppointmentSection" spacing="20" visible="false">
                <Label text="Book Appointment" styleClass="section-title">
                    <font>
                        <Font name="System Bold" size="24"/>
                    </font>
                </Label>

                <VBox spacing="15" styleClass="form-container" maxWidth="600">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>

                    <VBox spacing="5">
                        <Label text="Select Doctor:"/>
                        <ComboBox fx:id="cmbSelectDoctor" promptText="Choose a doctor..." maxWidth="Infinity"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Appointment Date:"/>
                        <DatePicker fx:id="dpAppointmentDate" maxWidth="Infinity"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Appointment Time:"/>
                        <ComboBox fx:id="cmbAppointmentTime" promptText="Choose time slot..." maxWidth="Infinity"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Visit Reason:"/>
                        <TextArea fx:id="txtVisitReason" promptText="Describe your symptoms or reason for visit..." prefRowCount="5"/>
                    </VBox>

                    <Button text="Submit Appointment" styleClass="primary-btn" onAction="#submitAppointment" maxWidth="200"/>
                </VBox>
            </VBox>

            <!-- View Appointments Section -->
            <VBox fx:id="viewAppointmentsSection" spacing="20" visible="false">
                <Label text="My Appointments" styleClass="section-title">
                    <font>
                        <Font name="System Bold" size="24"/>
                    </font>
                </Label>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Filter:"/>
                    <ComboBox fx:id="cmbAppointmentFilter" onAction="#filterAppointments" prefWidth="150" styleClass="filter-combo"/>
                </HBox>

                <ScrollPane fitToWidth="true" styleClass="transparent-scroll" VBox.vgrow="ALWAYS">
                    <FlowPane fx:id="gridAppointments" hgap="20" vgap="20" styleClass="appointment-grid">
                        <padding>
                            <Insets top="10" right="10" bottom="10" left="10"/>
                        </padding>
                    </FlowPane>
                </ScrollPane>
            </VBox>

            <!-- View Reports Section -->
            <VBox fx:id="viewReportsSection" spacing="20" visible="false">
                <Label text="Medical Reports" styleClass="section-title">
                    <font>
                        <Font name="System Bold" size="24"/>
                    </font>
                </Label>

                <TableView fx:id="tblReports" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colReportDoctor" text="Doctor" prefWidth="130"/>
                        <TableColumn fx:id="colDiagnosis" text="Diagnosis" prefWidth="180"/>
                        <TableColumn fx:id="colPrescription" text="Prescription" prefWidth="200"/>
                        <TableColumn fx:id="colNotes" text="Notes" prefWidth="200"/>
                        <TableColumn fx:id="colReportDate" text="Date" prefWidth="120"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- Notifications Section -->
            <VBox fx:id="notificationsSection" spacing="20" visible="false" managed="false">
                <Label text="Notifications" styleClass="section-title">
                    <font>
                        <Font name="System Bold" size="24"/>
                    </font>
                </Label>

                <Label text="Latest updates from admin and doctors" styleClass="info-text"/>

                <ListView fx:id="lstNotifications" VBox.vgrow="ALWAYS" styleClass="question-list"/>
            </VBox>

            <!-- Doctor Posts Section -->
            <VBox fx:id="doctorPostsSection" spacing="20" visible="false">
                <Label text="Health Tips &amp; Posts" styleClass="section-title">
                    <font>
                        <Font name="System Bold" size="24"/>
                    </font>
                </Label>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Category:"/>
                    <ComboBox fx:id="cmbPostCategory" onAction="#filterPosts" prefWidth="200"/>
                </HBox>

                <ListView fx:id="lstDoctorPosts" VBox.vgrow="ALWAYS" styleClass="post-list"/>
            </VBox>

            <!-- Q&A Section -->
            <VBox fx:id="qaSection" spacing="20" visible="false">
                <Label text="Q&amp;A Forum" styleClass="section-title">
                    <font>
                        <Font name="System Bold" size="24"/>
                    </font>
                </Label>

                <VBox spacing="10" styleClass="form-container">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>
                    <Label text="Ask a Question:" styleClass="form-label"/>
                    <TextArea fx:id="txtAskQuestion" promptText="Type your health-related question here..." prefRowCount="3"/>
                    <Button text="Submit Question" styleClass="primary-btn" onAction="#askQuestion" maxWidth="150"/>
                </VBox>

                <Label text="My Questions:" styleClass="subsection-title">
                    <font>
                        <Font name="System Bold" size="16"/>
                    </font>
                </Label>

                <ListView fx:id="lstMyQuestions" VBox.vgrow="ALWAYS" styleClass="question-list"/>
            </VBox>

            <!-- Blood Donation Section -->
            <VBox fx:id="bloodDonationSection" spacing="20" visible="false">
                <Label text="Blood Donation Network" styleClass="section-title">
                    <font>
                        <Font name="System Bold" size="24"/>
                    </font>
                </Label>

                <VBox fx:id="donorRegistrationForm" spacing="15" styleClass="form-container" maxWidth="600">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>

                    <Label text="Join as Blood Donor" styleClass="subsection-title">
                        <font>
                            <Font name="System Bold" size="16"/>
                        </font>
                    </Label>

                    <HBox spacing="10">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Blood Group:"/>
                            <ComboBox fx:id="cmbBloodGroup" promptText="Select..." maxWidth="Infinity"/>
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Availability:"/>
                            <ComboBox fx:id="cmbAvailabilityStatus" maxWidth="Infinity"/>
                        </VBox>
                    </HBox>

                    <VBox spacing="5">
                        <Label text="Location:"/>
                        <TextField fx:id="txtDonorLocation" promptText="Your location..."/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Phone:"/>
                        <TextField fx:id="txtDonorPhone" promptText="Contact number..."/>
                    </VBox>

                    <Button text="Register as Donor" styleClass="primary-btn" onAction="#joinAsDonor" maxWidth="200"/>
                </VBox>

                <Separator/>

                <Label text="Available Blood Donors" styleClass="subsection-title">
                    <font>
                        <Font name="System Bold" size="16"/>
                    </font>
                </Label>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="txtSearchBloodGroup" promptText="Enter blood group (e.g., A+, O-)..." prefWidth="250"/>
                    <Button text="Search" styleClass="primary-btn" onAction="#searchDonors"/>
                    <Button text="Show All" styleClass="secondary-btn" onAction="#showBloodDonation"/>
                </HBox>

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
                    <FlowPane fx:id="donorGridPane" hgap="20" vgap="20" prefWrapLength="1200" styleClass="doctor-grid-container">
                        <padding>
                            <Insets top="10" right="10" bottom="10" left="10"/>
                        </padding>
                    </FlowPane>
                </ScrollPane>
            </VBox>

            <!-- Smart Assistant Section -->
            <VBox fx:id="smartAssistantSection" spacing="20" visible="false">
                <Label text="Smart Health Assistant" styleClass="section-title">
                    <font>
                        <Font name="System Bold" size="24"/>
                    </font>
                </Label>

                <Label text="Describe your symptoms and get AI-powered recommendations" styleClass="info-text"/>

                <VBox spacing="15" styleClass="form-container">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>

                    <VBox spacing="5">
                        <Label text="Symptoms:" styleClass="form-label"/>
                        <TextArea fx:id="txtSymptoms" promptText="Describe your symptoms in detail (e.g., fever, headache, cough...)..." prefRowCount="5"/>
                    </VBox>

                    <Button text="Analyze Symptoms" styleClass="primary-btn" onAction="#analyzeSymptoms" maxWidth="200"/>

                    <Separator/>

                    <VBox spacing="5">
                        <Label text="Recommendation:" styleClass="form-label"/>
                        <TextArea fx:id="txtAssistantResponse" editable="false" wrapText="true" prefRowCount="10" styleClass="response-area"/>
                    </VBox>
                </VBox>
            </VBox>

        </StackPane>
    </center>

</BorderPane>
