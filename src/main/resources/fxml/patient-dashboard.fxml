<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<AnchorPane prefHeight="768.0" prefWidth="1024.0" styleClass="dashboard-root" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.project.controller.PatientDashboardController">
    <children>
        <HBox prefHeight="768.0" prefWidth="1024.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <!-- Sidebar -->
            <VBox prefWidth="260.0" styleClass="sidebar">
                <children>
                    <VBox alignment="CENTER" spacing="15.0" styleClass="sidebar-header">
                        <padding>
                            <Insets bottom="30.0" top="30.0" />
                        </padding>
                        <ImageView fitHeight="60.0" fitWidth="60.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../images/logo.png" />
                            </image>
                        </ImageView>
                        <Label styleClass="sidebar-brand" text="BUET MedTech" />
                    </VBox>

                    <ScrollPane fitToWidth="true" styleClass="sidebar-scroll" VBox.vgrow="ALWAYS">
                        <content>
                            <VBox spacing="5.0" styleClass="sidebar-menu">
                                <padding>
                                    <Insets left="15.0" right="15.0" top="10.0" />
                                </padding>
                                <Button alignment="BASELINE_LEFT" graphicTextGap="15.0" maxWidth="Infinity" styleClass="menu-item, menu-item-active" text="Dashboard">
                                    <graphic><Label styleClass="menu-icon" text="🏠" /></graphic>
                                </Button>
                                <Button alignment="BASELINE_LEFT" graphicTextGap="15.0" maxWidth="Infinity" styleClass="menu-item" text="Find Doctor">
                                    <graphic><Label styleClass="menu-icon" text="🔍" /></graphic>
                                </Button>
                                <Button alignment="BASELINE_LEFT" graphicTextGap="15.0" maxWidth="Infinity" styleClass="menu-item" text="My Appointments">
                                    <graphic><Label styleClass="menu-icon" text="📅" /></graphic>
                                </Button>
                                <Button alignment="BASELINE_LEFT" graphicTextGap="15.0" maxWidth="Infinity" styleClass="menu-item" text="My Reports">
                                    <graphic><Label styleClass="menu-icon" text="📄" /></graphic>
                                </Button>
                                <Button alignment="BASELINE_LEFT" graphicTextGap="15.0" maxWidth="Infinity" styleClass="menu-item" text="Health Tips Feed">
                                    <graphic><Label styleClass="menu-icon" text="📰" /></graphic>
                                </Button>
                                <Button alignment="BASELINE_LEFT" graphicTextGap="15.0" maxWidth="Infinity" styleClass="menu-item" text="Blood Network">
                                    <graphic><Label styleClass="menu-icon" text="🩸" /></graphic>
                                </Button>
                                <Button alignment="BASELINE_LEFT" graphicTextGap="15.0" maxWidth="Infinity" styleClass="menu-item" text="Symptom Checker">
                                    <graphic><Label styleClass="menu-icon" text="🤖" /></graphic>
                                </Button>
                            </VBox>
                        </content>
                    </ScrollPane>

                    <VBox spacing="10.0" styleClass="sidebar-footer">
                        <padding>
                            <Insets bottom="20.0" left="15.0" right="15.0" top="10.0" />
                        </padding>
                        <Button alignment="BASELINE_LEFT" graphicTextGap="15.0" maxWidth="Infinity" onAction="#handleLogout" styleClass="logout-btn" text="Logout">
                            <graphic><Label styleClass="menu-icon" text="🚪" /></graphic>
                        </Button>
                    </VBox>
                </children>
            </VBox>

            <!-- Main Content Area -->
            <VBox styleClass="main-content" HBox.hgrow="ALWAYS">
                <children>
                    <!-- Top Navigation Bar -->
                    <HBox alignment="CENTER_LEFT" prefHeight="80.0" styleClass="top-bar">
                        <padding>
                            <Insets left="30.0" right="30.0" />
                        </padding>
                        <Label fx:id="welcomeLabel" styleClass="welcome-text" text="Welcome, Patient!" />
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER" spacing="15.0">
                            <StackPane styleClass="notif-icon">
                                <Label style="-fx-font-size: 20px;" text="🔔" />
                                <Circle fill="#ef4444" radius="4.0" StackPane.alignment="TOP_RIGHT">
                                    <StackPane.margin>
                                        <Insets right="2.0" top="2.0" />
                                    </StackPane.margin>
                                </Circle>
                            </StackPane>
                            <Separator orientation="VERTICAL" prefHeight="30.0" />
                            <HBox alignment="CENTER" spacing="10.0" onMouseClicked="#handleProfileUpdate" styleClass="profile-trigger" style="-fx-cursor: hand;">
                                <Label fx:id="userNameLabel" styleClass="profile-name" text="User Name" />
                                <ImageView fitHeight="35.0" fitWidth="35.0">
                                    <image>
                                        <Image url="@../images/logo.png" />
                                    </image>
                                    <clip>
                                        <Circle centerX="17.5" centerY="17.5" radius="17.5" />
                                    </clip>
                                </ImageView>
                            </HBox>
                        </HBox>
                    </HBox>

                    <!-- Scrollable Content -->
                    <ScrollPane fitToWidth="true" styleClass="content-scroll" VBox.vgrow="ALWAYS">
                        <content>
                            <VBox spacing="30.0">
                                <padding>
                                    <Insets bottom="40.0" left="30.0" right="30.0" top="30.0" />
                                </padding>
                                
                                <!-- Stats Cards -->
                                <HBox spacing="20.0">
                                    <children>
                                        <VBox styleClass="stat-card, card-blue" HBox.hgrow="ALWAYS">
                                            <Label styleClass="stat-title" text="Upcoming" />
                                            <Label styleClass="stat-value" text="02" />
                                            <Label styleClass="stat-desc" text="Appointments" />
                                        </VBox>
                                        <VBox styleClass="stat-card, card-green" HBox.hgrow="ALWAYS">
                                            <Label styleClass="stat-title" text="Total" />
                                            <Label styleClass="stat-value" text="08" />
                                            <Label styleClass="stat-desc" text="Reports" />
                                        </VBox>
                                        <VBox styleClass="stat-card, card-orange" HBox.hgrow="ALWAYS">
                                            <Label styleClass="stat-title" text="Blood" />
                                            <Label styleClass="stat-value" text="B+" />
                                            <Label styleClass="stat-desc" text="Group" />
                                        </VBox>
                                    </children>
                                </HBox>

                                <!-- Main Grid Section -->
                                <GridPane hgap="25.0" vgap="25.0">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints vgrow="SOMETIMES" />
                                    </rowConstraints>
                                    <children>
                                        <!-- Recent Appointments -->
                                        <VBox spacing="15.0" styleClass="content-card" GridPane.columnIndex="0">
                                            <HBox alignment="CENTER_LEFT">
                                                <Label styleClass="card-header" text="Upcoming Appointments" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Button styleClass="view-all-btn" text="View All" />
                                            </HBox>
                                            <VBox spacing="10.0" styleClass="data-list">
                                                <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="list-item">
                                                    <VBox alignment="CENTER" styleClass="date-badge">
                                                        <Label styleClass="date-day" text="20" />
                                                        <Label styleClass="date-month" text="MAR" />
                                                    </VBox>
                                                    <VBox spacing="2.0">
                                                        <Label styleClass="item-primary" text="Dr. Ahmed Sharif" />
                                                        <Label styleClass="item-secondary" text="Cardiology • 10:30 AM" />
                                                    </VBox>
                                                    <Region HBox.hgrow="ALWAYS" />
                                                    <Label styleClass="status-badge, status-confirmed" text="Confirmed" />
                                                </HBox>
                                            </VBox>
                                        </VBox>

                                        <!-- Recent Health Tips -->
                                        <VBox spacing="15.0" styleClass="content-card" GridPane.columnIndex="1">
                                            <HBox alignment="CENTER_LEFT">
                                                <Label styleClass="card-header" text="Latest Health Tips" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Button styleClass="view-all-btn" text="Explore" />
                                            </HBox>
                                            <VBox spacing="12.0">
                                                <VBox spacing="5.0" styleClass="tip-item">
                                                    <Label styleClass="tip-title" text="How to maintain a healthy heart?" />
                                                    <Label styleClass="tip-author" text="By Dr. Sarah Khan • 2 days ago" />
                                                </VBox>
                                                <Separator />
                                                <VBox spacing="5.0" styleClass="tip-item">
                                                    <Label styleClass="tip-title" text="Benefits of drinking water in the morning." />
                                                    <Label styleClass="tip-author" text="By Dr. Faisal Ahmed • 5 days ago" />
                                                </VBox>
                                            </VBox>
                                        </VBox>
                                    </children>
                                </GridPane>
                            </VBox>
                        </content>
                    </ScrollPane>
                </children>
            </VBox>
        </HBox>
    </children>
</AnchorPane>
