<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane  styleClass="login-root" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.project.controller.LoginController">

    <children>
        <HBox  spacing="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

            <!-- Left side (Illustration/Image) -->
            <AnchorPane styleClass="login-left-pane" HBox.hgrow="ALWAYS" >
                <children>
                    <ImageView fitHeight="768.0" fitWidth="512.0" preserveRatio="false" smooth="true" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                        <image>
                            <Image url="@../images/role-select.png" />
                        </image>
                    </ImageView>
                    <!-- Overlay if needed -->
                    <VBox alignment="CENTER" spacing="20" style="-fx-background-color: rgba(11, 18, 36, 0.4);" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />
                </children>
            </AnchorPane>

            <!-- Right side (Login Form) -->
            <StackPane styleClass="login-right-pane" HBox.hgrow="ALWAYS" >
                <children>
                    <!-- Form Area -->
                    <VBox alignment="CENTER_LEFT" maxWidth="512" spacing="25.0" styleClass="login-card">
                        <HBox alignment="CENTER_LEFT">
                            <Button onAction="#handleBack" styleClass="back-btn-minimal">
                                <graphic>
                                    <ImageView fitHeight="32.0" fitWidth="32.0" pickOnBounds="true" preserveRatio="true">
                                        <image>
                                            <Image url="@../images/back-icon.png" />
                                        </image>
                                    </ImageView>
                                </graphic>
                            </Button>
                        </HBox>

                        <VBox spacing="8.0">
                            <Label fx:id="roleLabel" styleClass="login-role-tag" text="ADMIN LOGIN" />
                            <Label styleClass="login-title" text="Welcome Back" />
                            <Label styleClass="login-subtitle" text="Please enter your details to sign in." />
                        </VBox>

                        <!-- Error Message Label -->
                        <Label fx:id="errorLabel" managed="false" maxWidth="400.0" styleClass="error-label" visible="false" wrapText="true" />

                        <VBox spacing="15.0">
                            <!-- Email/Username -->
                            <VBox spacing="6.0">
                                <Label styleClass="input-label" text="Email or Username" />
                                <TextField fx:id="usernameField" prefHeight="50.0" promptText="Enter your email or username" styleClass="text-field-custom" />
                            </VBox>

                            <!-- Password -->
                            <VBox spacing="6.0">
                                <Label styleClass="input-label" text="Password" />
                                <PasswordField fx:id="passwordField" prefHeight="50.0" promptText="••••••••" styleClass="text-field-custom" />
                                <HBox alignment="CENTER_RIGHT">
                                    <Label style="-fx-font-size: 12px;" styleClass="register-action" text="Forgot password?" />
                                </HBox>
                            </VBox>
                        </VBox>

                        <Button fx:id="loginBtn" onAction="#handleLogin" prefWidth="400.0" styleClass="login-primary-btn" text="Sign In" />

                        <HBox alignment="CENTER" spacing="5.0">
                            <Label styleClass="register-link" text="Don't have an account?" />
                            <Label onMouseClicked="#handleRegisterRedirect" styleClass="register-action" text="Register Now" />
                        </HBox>
                    </VBox>
                </children>
            </StackPane>
        </HBox>
    </children>
</AnchorPane>
