<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane  styleClass="login-root" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.project.controller.RegisterController">

    <children>
        <HBox  spacing="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

            <!-- Left side (Illustration/Image) -->
            <AnchorPane styleClass="login-left-pane" HBox.hgrow="ALWAYS">
                <children>
                    <ImageView fitHeight="768.0" fitWidth="512.0" preserveRatio="false" smooth="true" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                        <image>
                            <Image url="@../images/role-select.png" />
                        </image>
                    </ImageView>
                    <!-- Overlay if needed -->
                    <VBox alignment="CENTER" spacing="20" style="-fx-background-color: rgba(11, 18, 36, 0.4);" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />
                </children>
            </AnchorPane>

            <!-- Right side (Register Form) -->
            <StackPane  styleClass="login-right-pane" HBox.hgrow="ALWAYS">
                <children>
                    <!-- Form Area -->
                    <VBox alignment="CENTER_LEFT" maxWidth="512" spacing="20.0" styleClass="login-card">
                        <VBox spacing="6.0">
                            <Label fx:id="roleLabel" styleClass="login-role-tag" text="PATIENT REGISTRATION" />
                            <Label styleClass="login-title" text="Create Account" />
                            <Label styleClass="login-subtitle" text="Join our healthcare network today." />
                        </VBox>

                        <!-- Error Message Label -->
                        <Label fx:id="errorLabel" managed="false" maxWidth="420.0" styleClass="error-label" visible="false" wrapText="true" />

                        <VBox spacing="12.0">
                            <!-- Full Name -->
                            <VBox spacing="4.0">
                                <Label styleClass="input-label" text="Full Name" />
                                <TextField fx:id="nameField" prefHeight="45.0" promptText="Sadman Sakib" styleClass="text-field-custom" />
                            </VBox>

                            <!-- Email -->
                            <VBox spacing="4.0">
                                <Label styleClass="input-label" text="Email Address" />
                                <TextField fx:id="emailField" prefHeight="45.0" promptText="sadman@example.com" styleClass="text-field-custom" />
                            </VBox>

                            <!-- Password -->
                            <VBox spacing="4.0">
                                <Label styleClass="input-label" text="Password" />
                                <PasswordField fx:id="passwordField" prefHeight="45.0" promptText="••••••••" styleClass="text-field-custom" />
                            </VBox>

                            <!-- Confirm Password -->
                            <VBox spacing="4.0">
                                <Label styleClass="input-label" text="Confirm Password" />
                                <PasswordField fx:id="confirmPasswordField" prefHeight="45.0" promptText="••••••••" styleClass="text-field-custom" />
                            </VBox>
                        </VBox>

                        <Button fx:id="registerBtn" onAction="#handleRegister" prefWidth="420.0" styleClass="login-primary-btn" text="Register" />

                        <HBox alignment="CENTER" spacing="5.0">
                            <Label styleClass="register-link" text="Already have an account?" />
                            <Label onMouseClicked="#handleBackToLoginMouse" styleClass="register-action" text="Sign In" />
                        </HBox>
                    </VBox>
                </children>
            </StackPane>
        </HBox>
    </children>
</AnchorPane>
