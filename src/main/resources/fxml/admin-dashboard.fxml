<?xml version="1.0" encoding="UTF-8"?>

        <?import javafx.scene.layout.*?>
        <?import javafx.scene.control.*?>
        <?import javafx.scene.chart.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="AdminDashboardController">

    <!-- Sidebar -->
    <left>
        <VBox prefWidth="230" spacing="10"
              style="-fx-background-color:#111827; -fx-padding:15;">

            <Label text="Admin Panel"
                   style="-fx-text-fill:white; -fx-font-size:18; -fx-font-weight:bold;"/>

            <Separator/>

            <Button text="🏠 Dashboard" maxWidth="Infinity"/>
            <Button text="👨‍⚕ Manage Doctors" maxWidth="Infinity"/>
            <Button text="🧑‍🤝‍🧑 Manage Patients" maxWidth="Infinity"/>
            <Button text="📅 Manage Appointments" maxWidth="Infinity"/>
            <Button text="🏥 Departments" maxWidth="Infinity"/>
            <Button text="💰 Billing" maxWidth="Infinity"/>
            <Button text="📊 Reports" maxWidth="Infinity"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="⚙ System Settings"/>
            <Button text="🚪 Logout"/>
        </VBox>
    </left>

    <!-- Top -->
    <top>
        <HBox style="-fx-background-color:white; -fx-padding:10;">
            <Label text="Admin Dashboard"
                   style="-fx-font-size:18; -fx-font-weight:bold;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="Administrator"/>
        </HBox>
    </top>

    <!-- Content -->
    <center>
        <VBox spacing="20" style="-fx-padding:20; -fx-background-color:#f1f5f9;">

            <!-- Stats -->
            <HBox spacing="20">

                <VBox style="-fx-background-color:white; -fx-padding:15; -fx-background-radius:10;">
                    <Label text="Total Doctors"/>
                    <Label text="40" style="-fx-font-size:22;"/>
                </VBox>

                <VBox style="-fx-background-color:white; -fx-padding:15; -fx-background-radius:10;">
                    <Label text="Total Patients"/>
                    <Label text="1500"/>
                </VBox>

                <VBox style="-fx-background-color:white; -fx-padding:15; -fx-background-radius:10;">
                    <Label text="Appointments Today"/>
                    <Label text="85"/>
                </VBox>

                <VBox style="-fx-background-color:white; -fx-padding:15; -fx-background-radius:10;">
                    <Label text="Revenue Today"/>
                    <Label text="$5200"/>
                </VBox>

            </HBox>

            <!-- Charts -->
            <HBox spacing="20">

                <PieChart title="Department Distribution" prefWidth="350"/>

                <BarChart title="Appointments per Day">
                    <xAxis>
                        <CategoryAxis label="Day"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Appointments"/>
                    </yAxis>
                </BarChart>

            </HBox>

        </VBox>
    </center>

</BorderPane>

